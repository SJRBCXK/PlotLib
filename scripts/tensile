import matplotlib.pyplot as plt
from matplotlib.ticker import FuncFormatter, LogLocator
import numpy as np
import scipy as sp


from src.dataloader import Dataloader
from src.plotter import DataPlotter
from src.dataset import DataSet
from src.processor import DataProcessLayer as DPL
from src.processor import DataTransformer as DT
from src.formatters import make_axes_formatter, make_lines_formatter, make_legend_formatter

plt.close('all')

INPUT_COLUMNS_PER_DATASET = 5  # 每组数据集的列数
INPUT_DATASET_FRACTION = 1/INPUT_COLUMNS_PER_DATASET

dataRowNum_unit1 = 0  
dataRowNum_unit2 = 1  
dataRowNum_unit3 = 2  
dataRowNum_unit4 = 3  


Tensile_formatter = make_axes_formatter(
    xscale_type='linear',
    yscale_type='linear',
    x_format='{x:.2f}',
    y_format='{y:.2f}'
)


data = Dataloader(
    DATASET_FRACTION = INPUT_DATASET_FRACTION,
    COLUMNS_PER_DATASET = INPUT_COLUMNS_PER_DATASET
).load_data()


def cal_EB(data):
    """计算断裂伸长率：从强度峰值向后搜索应力下降拐点，返回对应应变"""
    # 过滤 NaN 行（不同组行数不同时 expandata 会补 NaN）
    mask = ~np.isnan(data).any(axis=1)
    data = data[mask]

    strain = data[:, 0]
    stress = data[:, 1]

    position = np.argmax(stress)

    print(f"峰值位置: {position}, 峰值应力: {stress[position]:.2f} MPa, 峰值应变: {strain[position]:.2f}%")

    while position < len(stress) - 1:
        k = abs(stress[position] - stress[position + 1]) - stress[position + 1]
        if k > 0:
            break
        position += 1

    return np.array([[strain[position]]])


Selected_data = DPL(data).select("应变","应力(MPa)").Selected_data
EB_data = DataSet()
for dataslice in Selected_data.iter('groups'): #type: ignore
    EB_slice = DT(dataslice).apply(func = cal_EB) #type: ignore
    EB_data.expandata(EB_slice)
print(EB_data.data)
print(EB_data.names)


Tensile = DataPlotter(
    input_dataset=data,#type: ignore
).subplotter_yy(
    plotdataRowNum_Y1=2,
    plotdataRowNum_Y2=1,
    axes_formatter=Tensile_formatter
)

    
plt.show()


